<!DOCTYPE html>
<html>
<head>
  <title>GeoMatch</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <% if user_signed_in? %>
    <meta name="current-user-id" content="<%= current_user.id %>">
  <% end %>

  <link rel="manifest" href="/manifest.json">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Geomatch">
  <meta name="mapbox-token" content="<%= ENV['MAPBOX_TOKEN'] %>">

  <link rel="apple-touch-icon" href="/icon.png">
  <link rel="apple-touch-icon" href="/icon-iphone.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/icon-iphone.png">
  <%= tag.link rel: "manifest", href: pwa_manifest_path %>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <% unless user_signed_in? %>
  <meta name="turbo-cache-control" content="no-cache">
  <% end %>

  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <meta name="vapid-public-key" content="<%= ENV["VAPID_PUBLIC_KEY"] %>">
  <script src="https://cdn.jsdelivr.net/npm/@turf/turf@7/turf.min.js"></script>
</head>

<%# A classe "turbo-native" no body permite esconder/mostrar elementos via CSS
    sem depender de lógica de servidor em cada view individual. %>
<body class="<%= 'turbo-native' if turbo_native_app? %>"
      data-turbo-native="<%= turbo_native_app? %>">

  <% if user_signed_in? %>
    <div class="authenticated-layout">
      <%# Sidebar oculta no app nativo — a navegação fica a cargo do Navigator iOS %>
      <% unless turbo_native_app? %>
        <%= render 'layouts/sidebar' %>
      <% end %>

      <main class="site-content">
        <%= yield %>
      </main>
    </div>

  <% else %>
    <%# Header público oculto no app nativo %>
    <% unless turbo_native_app? %>
      <header class="site-header">
        <div class="container header-inner">
          <%= link_to root_path, class: "brand" do %>
            <img src="<%= asset_path('logo-geomatch.svg') %>" alt="GeoMatch" class="brand-logo" />
          <% end %>
          <nav class="nav">
            <%= link_to "Entrar", new_user_session_path, class: "btn btn-outline" %>
            <%= link_to "Cadastrar", new_user_registration_path, class: "btn btn-primary" %>
          </nav>
        </div>
      </header>
    <% end %>

    <main class="site-content">
      <%= yield %>
    </main>
  <% end %>

  <%# Footer oculto no app nativo %>
  <% unless user_signed_in? || turbo_native_app? %>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-top">
          <p>O GeoMatch faz parte da GeoMatch Inc.</p>
        </div>
        <div class="footer-links">
          <div class="footer-column">
            <h4>Sobre</h4>
            <ul>
              <li><%= link_to "Vagas", "#" %></li>
              <li><%= link_to "Acessibilidade", "#" %></li>
              <li><%= link_to "Informações Gerais", "#" %></li>
              <li><%= link_to "Blog do GeoMatch", "#" %></li>
            </ul>
          </div>
          <div class="footer-column">
            <h4>Ajuda</h4>
            <ul>
              <li><%= link_to "Central de Ajuda", "#" %></li>
              <li><%= link_to "Centro de Segurança", "#" %></li>
              <li><%= link_to "Relatório de Confiança", "#" %></li>
              <li><%= link_to "Contato", "#" %></li>
            </ul>
          </div>
          <div class="footer-column">
            <h4>Legal</h4>
            <ul>
              <li><%= link_to "Termos de Uso", terms_of_use_path %></li>
              <li><%= link_to "Política de Privacidade", privacy_policy_path %></li>
              <li><%= link_to "Regras de Participação", "#" %></li>
              <li><%= link_to "Política de Cookies", "#" %></li>
            </ul>
          </div>
          <div class="footer-column">
            <h4>Conecte-se</h4>
            <ul class="social-links">
              <li><%= link_to image_tag("facebook.png",  alt: "Facebook GeoMatch"),  "#" %></li>
              <li><%= link_to image_tag("linkedin.png",  alt: "LinkedIn GeoMatch"),  "#" %></li>
              <li><%= link_to image_tag("instagram.png", alt: "Instagram GeoMatch"), "#" %></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <div class="app-links">
            <p>Baixe o app:</p>
            <%= link_to image_tag("appstore.png",   alt: "Baixe no App Store"),  "#" %>
            <%= link_to image_tag("googleplay.png", alt: "Baixe no Google Play"), "#" %>
          </div>
          <p class="copyright">
            &copy; 2006 – <%= Time.current.year %> GeoMatch. Todos os direitos reservados.
          </p>
        </div>
      </div>
    </footer>
  <% end %>

  <%= javascript_include_tag "application", type: "module", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "chat_logic", type: "module" %>

  <script>
    (function() {
      const theme = localStorage.getItem('theme-preference') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (theme === 'dark') {
        document.documentElement.classList.add('dark-mode');
      }
    })();
  </script>
</body>
</html>
